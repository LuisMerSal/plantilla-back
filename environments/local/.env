# Local Environment Configuration
NODE_ENV=local
PORT=3000

# Database Configuration
DATABASE_URL="postgresql://local_user:local_password@localhost:5432/ecommerce_local_db"

# JWT Configuration
JWT_SECRET="local-jwt-secret-key-change-in-production"
JWT_EXPIRES_IN="1d"

# API Key for Local Development
API_KEY="local-api-key-67890-change-in-production"

# Application Configuration
APP_NAME="eCommerce API - Local"
APP_VERSION="1.0.0"

# CORS Configuration
CORS_ORIGIN="http://localhost:3000"

# Local specific settings
LOG_LEVEL="info"
ENABLE_DOCS=true

