import { PrismaClient, Role } from '@prisma/client';
import * as bcrypt from 'bcryptjs';

const prisma = new PrismaClient();

async function main() {
  console.log('🌱 Starting database seeding...');

  // Create test users
  const adminUser = await prisma.user.upsert({
    where: { email: 'admin@ecommerce.com' },
    update: {},
    create: {
      email: 'admin@ecommerce.com',
      password: '$2b$10$V7MCWbuMDjLF2VgHSLZyY.7rDyIVzhi8sQ7.mKVOeeO8Bng5Nruo6',
      name: 'Administrator',
      dni: '12345678A',
      firstName: 'Admin',
      lastName: 'User',
      role: Role.ADMIN,
    },
  });

  const normalUser = await prisma.user.upsert({
    where: { email: 'user@ecommerce.com' },
    update: {},
    create: {
      email: 'user@ecommerce.com',
      password: '$2b$10$V7MCWbuMDjLF2VgHSLZyY.7rDyIVzhi8sQ7.mKVOeeO8Bng5Nruo6',
      name: 'Test User',
      dni: '87654321B',
      firstName: 'Test',
      lastName: 'User',
      role: Role.USER,
    },
  });

  console.log('✅ Created users:', { adminUser, normalUser });

  // Create sample products (use name as unique identifier)
  const products = await Promise.all([
    prisma.product.upsert({
      where: { name: 'Laptop Gaming' },
      update: {},
      create: {
        name: 'Laptop Gaming',
        description: 'High-performance gaming laptop with RTX graphics',
        price: 1299.99,
        stock: 10,
        imageUrl: 'https://example.com/laptop.jpg',
        isActive: true,
      },
    }),
    prisma.product.upsert({
      where: { name: 'Wireless Mouse' },
      update: {},
      create: {
        name: 'Wireless Mouse',
        description: 'Ergonomic wireless mouse with RGB lighting',
        price: 49.99,
        stock: 50,
        imageUrl: 'https://example.com/mouse.jpg',
        isActive: true,
      },
    }),
    prisma.product.upsert({
      where: { name: 'Mechanical Keyboard' },
      update: {},
      create: {
        name: 'Mechanical Keyboard',
        description: 'RGB mechanical keyboard with blue switches',
        price: 129.99,
        stock: 25,
        imageUrl: 'https://example.com/keyboard.jpg',
        isActive: true,
      },
    }),
    prisma.product.upsert({
      where: { name: 'Monitor 4K' },
      update: {},
      create: {
        name: 'Monitor 4K',
        description: '27-inch 4K monitor with HDR support',
        price: 399.99,
        stock: 15,
        imageUrl: 'https://example.com/monitor.jpg',
        isActive: true,
      },
    }),
    prisma.product.upsert({
      where: { name: 'Headphones' },
      update: {},
      create: {
        name: 'Headphones',
        description: 'Noise-cancelling wireless headphones',
        price: 199.99,
        stock: 30,
        imageUrl: 'https://example.com/headphones.jpg',
        isActive: true,
      },
    }),
  ]);

  console.log('✅ Created products:', products.length);

  // Create a sample cart for the normal user (use userId as unique)
  const cart = await prisma.cart.upsert({
    where: { userId: normalUser.id },
    update: {},
    create: {
      userId: normalUser.id,
    },
  });

  // Add items to the cart
  await prisma.cartItem.createMany({
    data: [
      {
        cartId: cart.id,
        productId: products[1].id, // Wireless Mouse
        quantity: 2,
      },
      {
        cartId: cart.id,
        productId: products[2].id, // Mechanical Keyboard
        quantity: 1,
      },
    ],
    skipDuplicates: true,
  });

  console.log('✅ Created sample cart with items');

  // Create a sample order
  const order = await prisma.order.create({
    data: {
      userId: normalUser.id,
      status: 'CONFIRMED',
      totalAmount: 229.97, // (49.99 * 2) + 129.99
      items: {
        create: [
          {
            productId: products[1].id, // Wireless Mouse
            quantity: 2,
            price: 49.99,
          },
          {
            productId: products[2].id, // Mechanical Keyboard
            quantity: 1,
            price: 129.99,
          },
        ],
      },
    },
  });

  // Create a payment for the order
  await prisma.payment.create({
    data: {
      orderId: order.id,
      userId: normalUser.id,
      amount: 229.97,
      status: 'COMPLETED',
      paymentMethod: 'credit_card',
      transactionId: 'tx_' + Date.now(),
    },
  });

  console.log('✅ Created sample order with payment');

  console.log('🎉 Database seeding completed successfully!');
  console.log('');
  console.log('📝 Test credentials (CHANGE IN PRODUCTION):');
  console.log('   Admin: admin@ecommerce.com / admin123');
  console.log('   User:  user@ecommerce.com / user123');
  console.log('');
  console.log('⚠️  SECURITY WARNING:');
  console.log('   Passwords are stored in plain text for testing purposes.');
  console.log(
    '   In production, implement proper password hashing with bcrypt.',
  );
}

main()
  .catch((e) => {
    console.error('❌ Error during seeding:', e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
